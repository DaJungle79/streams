{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Streams",
  "version": "0.1.0",
  "identifier": "com.ivailoivanov.streams",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Streams",
        "width": 1100,
        "height": 760,
        "minWidth": 820,
        "minHeight": 520,
        "visible": true
      },
      {
        "label": "capture",
        "title": "Quick capture",
        "width": 560,
        "height": 78,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "center": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "14.0"
    }
  }
}